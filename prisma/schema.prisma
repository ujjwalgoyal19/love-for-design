// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../apps/backend/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    role          UserRole  @default(USER)
    accounts      Account[]
    sessions      Session[]
    posts         Post[]

    // Design platform relationships
    designSessions DesignSession[]
    templates      Template[]
    questionTemplates QuestionTemplate[]
    createdAgents  AIAgent[]
    updatedSettings SystemSetting[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum UserRole {
    USER
    ADMIN
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// Design Platform Models

model DesignSession {
    id          String @id @default(cuid())
    title       String
    category    DesignCategory
    status      SessionStatus @default(ACTIVE)

    // User relationship
    userId      String
    user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Design data
    questions   Question[]
    answers     Answer[]
    canvasData  Json?
    narrative   String?
    canvasElements CanvasElement[]

    // Version control
    versions    SessionVersion[]
    currentVersion Int @default(1)

    // Exports
    exports     Export[]

    // Agent logs
    agentLogs   AgentExecutionLog[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([category])
    @@index([status])
}

enum DesignCategory {
    SOCIAL_MEDIA
    MESSAGING
    STREAMING
    ECOMMERCE
    SEARCH
    STORAGE
    ANALYTICS
    GAMING
}

enum SessionStatus {
    ACTIVE
    COMPLETED
    ARCHIVED
}

model Question {
    id            String @id @default(cuid())
    sessionId     String
    session       DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    text          String
    type          QuestionType
    category      String
    order         Int
    parentId      String?
    parent        Question? @relation("QuestionHierarchy", fields: [parentId], references: [id])
    children      Question[] @relation("QuestionHierarchy")

    // AI generation metadata
    generatedBy   String? // Agent ID
    context       Json?

    answers       Answer[]

    createdAt DateTime @default(now())

    @@index([sessionId])
    @@index([order])
    @@index([parentId])
}

model Answer {
    id          String @id @default(cuid())
    questionId  String
    question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

    sessionId   String
    session     DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    content     String
    metadata    Json?

    createdAt DateTime @default(now())

    @@index([questionId])
    @@index([sessionId])
}

enum QuestionType {
    MULTIPLE_CHOICE
    TEXT_INPUT
    SCALE
    BOOLEAN
}

model QuestionTemplate {
    id          String @id @default(cuid())
    text        String
    type        QuestionType
    category    DesignCategory
    order       Int?

    // Template metadata
    description String?
    isActive    Boolean @default(true)

    // AI generation hints
    context     Json?
    followUpRules Json? // Rules for generating follow-up questions

    // Ownership
    createdBy   String
    creator     User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([category])
    @@index([type])
    @@index([isActive])
    @@index([createdBy])
}

model SessionVersion {
    id          String @id @default(cuid())
    sessionId   String
    session     DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

    version     Int
    canvasData  Json
    narrative   String?
    snapshot    Json // Complete state snapshot
    canvasElements CanvasElement[]

    createdAt DateTime @default(now())

    @@index([sessionId])
    @@index([version])
    @@unique([sessionId, version])
}

model CanvasElement {
    id          String @id @default(cuid())
    sessionId   String
    session     DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    versionId   String
    version     SessionVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

    elementType CanvasElementType
    elementId   String  // ID from the canvas library
    data        Json    // Element-specific data
    position    Json    // x, y coordinates
    size        Json?   // width, height if applicable
    style       Json?   // Element styling

    // For AI-generated elements
    generatedBy String?
    prompt      String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([sessionId])
    @@index([versionId])
    @@index([elementType])
}

enum CanvasElementType {
    SHAPE
    CONNECTOR
    TEXT
    IMAGE
    GROUP
    AI_DIAGRAM
}

model Template {
    id          String @id @default(cuid())
    name        String
    description String?
    type        TemplateType
    content     Json // Template structure and styling

    // Ownership
    createdBy   String
    creator     User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
    isPublic    Boolean @default(false)

    // Usage tracking
    exports     Export[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([createdBy])
    @@index([type])
    @@index([isPublic])
}

model Export {
    id          String @id @default(cuid())
    sessionId   String
    session     DesignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    templateId  String
    template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

    format      ExportFormat
    status      ExportStatus @default(PENDING)
    fileUrl     String?
    errorMessage String?

    createdAt DateTime @default(now())
    completedAt DateTime?

    @@index([sessionId])
    @@index([status])
    @@index([templateId])
}

enum TemplateType {
    DESIGN_DOCUMENT
    PRESENTATION
    TECHNICAL_SPEC
}

enum ExportFormat {
    PDF
    DOCX
    HTML
}

enum ExportStatus {
    PENDING
    PROCESSING
    COMPLETED
    FAILED
}

model AIAgent {
    id            String @id @default(cuid())
    name          String
    description   String?
    model         String // e.g., "gpt-4", "claude-3"
    provider      String // e.g., "openai", "anthropic"
    capabilities  String[] // e.g., ["question_generation", "design_review"]

    // Configuration
    config        Json // Model-specific parameters
    isActive      Boolean @default(true)
    priority      Int @default(0)

    // Ownership
    createdBy     String
    creator       User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

    // Usage tracking
    requestCount  Int @default(0)
    lastUsed      DateTime?
    executionLogs AgentExecutionLog[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isActive])
    @@index([provider])
    @@index([createdBy])
}

model AgentExecutionLog {
    id            String @id @default(cuid())
    agentId       String
    agent         AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

    sessionId     String?
    session       DesignSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

    requestType   String
    input         Json
    output        Json?
    error         String?

    startTime     DateTime @default(now())
    endTime       DateTime?
    durationMs    Int?

    tokenUsage    Json? // { prompt_tokens, completion_tokens, total_tokens }

    @@index([agentId])
    @@index([sessionId])
    @@index([requestType])
    @@index([startTime])
}

model SystemSetting {
    id          String @id @default(cuid())
    key         String @unique
    value       Json
    description String?

    // Audit
    updatedBy   String?
    updatedByUser User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([key])
}